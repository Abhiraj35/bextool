{
  "name": "bextool",
  "version": "1.0.2",
  "description": "CLI for scaffolding browser extension starter projects",
  "bin": {
    "bextool": "src/index.js"
  },
  "keywords": [
    "cli",
    "browser-extension",
    "scaffolding",
    "chrome-extension",
    "firefox-addon",
    "extension",
    "manifest-v3"
  ],
  "homepage": "https://github.com/Abhiraj35/bextool#readme",
  "bugs": {
    "url": "https://github.com/Abhiraj35/bextool/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Abhiraj35/bextool.git"
  },
  "license": "ISC",
  "author": "Abhiraj (GitHub: Abhiraj35)",
  "contributors": [
    "Shubham Raj (GitHub: Shubham-1068)"
  ],
  "type": "module",
  "main": "./src/index.js",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "preferGlobal": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "check": "node --check src/index.js && node --check src/utils/file-generator.js && node --check src/utils/browser-configs.js",
    "test": "npm run check",
    "start": "node src/index.js",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "chalk": "^5.3.0",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "kleur": "^4.1.5"
  }
}
